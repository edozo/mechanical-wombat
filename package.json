{
  "name": "@edozo/mechanical-wombat",
  "version": "7.0.0",
  "description": "React UI component lib for edozo apps and sites",
  "author": "edozo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edozo/mechanical-wombat.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "homepage": "https://edozo.github.io/mechanical-wombat/",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./styled": {
      "types": "./dist/styled.d.ts"
    }
  },
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=20",
    "npm": ">=8"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.types.json",
    "start": "tsup --watch",
    "prepare": "yarn run build",
    "predeploy": "build-storybook",
    "storybook:clear-cache": "rm -rf node_modules/.cache/storybook",
    "storybook": "storybook dev -p 9009",
    "storybook_win": "yarn storybook:clear-cache&storybook dev -p 9009",
    "build-storybook": "storybook build",
    "lint": "eslint --ext .ts --ext .tsx src && yarn lint:css",
    "lintfix": "eslint --ext .ts --ext .tsx src --fix && yarn lint:css",
    "lint:css": "stylelint './src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "test": "test-storybook --url http://localhost:9009",
    "yarn:package": "yarn pack",
    "martin": "yarn build-storybook && aws s3 sync storybook-static/ s3://martin-test.edozo.co/",
    "harry": "yarn build-storybook && aws s3 sync storybook-static/ s3://harry-test.edozo.co/ --delete"
  },
  "dependencies": {
    "react-collapsed": "2.0.0"
  },
  "peerDependencies": {
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@tippyjs/react": "^4.2.6",
    "downshift": "^6.1.3",
    "lucide-react": "^0.510.0",
    "polished": "^4.1.3",
    "react": ">=18 <20",
    "react-dom": ">=18 <20",
    "styled-components": "^6.1.19",
    "styled-reboot": "^5.0.0"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/react": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@storybook/react-webpack5": "^10.2.19",
    "@storybook/test-runner": "^0.24.2",
    "@svgr/rollup": "^8.1.0",
    "@svgr/webpack": "^8.1.0",
    "@tippyjs/react": "^4.2.5",
    "@types/node": "^24.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "downshift": "^6.1.3",
    "esbuild-plugin-svgr": "^3.1.1",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.19.1",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.17.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "10.2.19",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "lucide-react": "^0.577.0",
    "polished": "^4.1.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^10.2.19",
    "styled-components": "^6.3.11",
    "stylelint": "^13.13.1",
    "stylelint-config-recommended": "^4.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-processor-styled-components": "^1.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "files": [
    "dist"
  ],
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint"
    ],
    "src/**/*.ts": [
      "stylelint"
    ]
  },
  "packageManager": "yarn@1.22.22"
}
